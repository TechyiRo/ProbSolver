{
  "version": 2,
  "builds": [
    { "src": "server.ts", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.ts" },
    { "src": "/image/(.*)", "dest": "/image/$1" },
    { "src": "/(.*)", "dest": "/$1", "headers": { "cache-control": "s-maxage=0" } }
  ]
}
